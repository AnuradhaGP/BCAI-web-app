pipeline {
    agent any

    environment {
        // Project name for docker-compose to group the containers
        COMPOSE_PROJECT_NAME = 'bcai-web-app'
    }

    stages {
        stage('Checkout Code') {
            steps {
                git branch: 'main', url: 'https://github.com/AnuradhaGP/BCAI-web-app.git'
            }
        }

        stage('Build & Deploy to Droplet') {
            steps {
                script {
                    echo "Building and deploying containers using Docker Compose..."
                    // Shut down existing containers if any
                    sh 'docker compose down'
                    
                    // Build new images and run them in background (-d)
                    sh 'docker compose up -d --build'
                }
            }
        }
        
        stage('Verify Deployment') {
            steps {
                script {
                    echo "Verifying running services..."
                    // List the running containers to ensure they are up
                    sh 'docker compose ps'
                }
            }
        }
    }

    post {
        always {
            echo "Deployment pipeline execution completed."
           
        }
        success {
            echo "Successfully deployed BCAI Web App "
        }
        failure {
            echo "Deployment failed. Please check the Jenkins logs."
        }
    }
}
